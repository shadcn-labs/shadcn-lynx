{
  "name": "shadcn-lynx-workspace",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:lynx": "pnpm --filter demo dev",
    "dev:docs": "pnpm --filter docs dev --port 3001",
    "dev:registry": "pnpm --filter @shadcn-lynx/registry dev",
    "build:lynx": "pnpm --filter demo build",
    "build:docs": "pnpm --filter docs build",
    "build:cli": "pnpm --filter shadcn-lynx build",
    "build:registry": "pnpm --filter @shadcn-lynx/registry build",
    "build": "pnpm --filter demo build && pnpm --filter docs build",
    "preview:lynx": "pnpm --filter demo preview",
    "preview:docs": "pnpm --filter docs preview",
    "check": "biome check --write",
    "format": "biome format --write",
    "test": "pnpm --filter demo test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14"
  },
  "engines": {
    "node": ">=18"
  }
}
